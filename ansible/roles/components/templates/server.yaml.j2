apiVersion: apps/v1
kind: Deployment
metadata:
  name: server
spec:
  replicas: {{ 3 * components_pod_num }}
  selector:
    matchLabels:
      app: server
  template:
    metadata:
      labels:
        app: server
    spec:
      topologySpreadConstraints:
        - maxSkew: 1
          topologyKey: kubernetes.io/hostname
          whenUnsatisfiable: ScheduleAnyway
          labelSelector:
            matchLabels:
              app: server
      containers:
        - name: http-echo
          image: hashicorp/http-echo:1.0
          args:
            - "-listen=:80"
            - "-text=server"
          ports:
            - containerPort: 80
---
apiVersion: v1
kind: Service
metadata:
  name: server
spec:
  selector:
    app: server
  ports:
    - name: http
      port: 80
      targetPort: 80
